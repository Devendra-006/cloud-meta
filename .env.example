# CloudCostEnv Environment Variables

# API Configuration
PORT=8000
HOST=0.0.0.0

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Baseline Model (for AI agent testing)
BASELINE_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
